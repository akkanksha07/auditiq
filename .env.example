# ─── AuditIQ environment configuration ────────────────────────────────────────
# Copy this file to `.env` and fill in your key:  cp .env.example .env

# Anthropic API key — required for AI extraction, narrative findings, and news
# sentiment (Claude + web search). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (sensible defaults shown).
# Extraction is high-volume/structured -> Sonnet. Use Opus for deeper narrative.
AUDITIQ_EXTRACTION_MODEL=claude-sonnet-4-6
AUDITIQ_NARRATIVE_MODEL=claude-sonnet-4-6
AUDITIQ_NEWS_MODEL=claude-sonnet-4-6

# Max PDF pages to scan for financial statements (keeps token cost bounded).
AUDITIQ_MAX_PDF_PAGES=60
